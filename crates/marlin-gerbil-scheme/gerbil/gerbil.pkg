(package: marlin-deck-runtime
 depend: ("github.com/tao3k/poo-flow@1367aff9865bcabc6cddf04cd41e157b25c7979a"
          "github.com/tao3k/gerbil-scheme-language-project-harness@ad1c2cd2806e8390167ece435bcc2ef456f8658c")
 policy: ((source-scope
           roots: ("src")
           runtime-roots: ("src")
           explanation: "Marlin runtime adapters live under gerbil/src; the POO module-system implementation is consumed from the poo-flow package dependency.")
          (modularity-policy
           config: "harness-policy/gerbil.ss"
           explanation: "Marlin applies modularity thresholds through a package-owned Gerbil policy file so policy can evolve without Rust harness changes.")
          (macro-governance
           allow-generated: #t
           explanation: "Marlin Gerbil runtime macro edits must cite runtime-source and macro-expansion evidence before changing transformers."
           witness: "search runtime-source macro sugar module-sugar")))
