load("@marlin_crates//:defs.bzl", "crate_deps", "crate_edition")
load("//bazel:marlin_harness.bzl", "marlin_harness_crate")

marlin_harness_crate(
    name = "marlin_workspace_protocol",
    srcs = glob(["src/**/*.rs"]),
    build_deps = ["//build-support/marlin-rust-project-harness-policy:marlin_rust_project_harness_policy"],
    edition = crate_edition(),
    gate_data = glob(["tests/**/*.rs"]),
    proc_macro_deps = crate_deps(["async-trait"]),
    deps = crate_deps([
        "serde",
        "thiserror",
    ]) + [
        "//crates/marlin-org-model:marlin_org_model",
        "//crates/marlin-org-patch:marlin_org_patch",
        "//crates/marlin-workspace-patch:marlin_workspace_patch",
        "//crates/marlin-workspace-query:marlin_workspace_query",
        "//crates/marlin-workspace-status:marlin_workspace_status",
        "//crates/marlin-workspace-view:marlin_workspace_view",
    ],
)
